# ============================================================
# REASONING CORE — .gitignore
# ============================================================

# ── SECRETS — NEVER COMMIT THESE ────────────────────────────
.env
.env.local
.env.*.local

# ── PYTHON ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/

# ── TESTING ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── DATA & LOCAL STORAGE ────────────────────────────────────
data/
*.db
*.sqlite

# ── IDE ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store

# ── LOGS ────────────────────────────────────────────────────
logs/
*.log